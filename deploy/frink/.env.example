# Flask Configuration
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_DEBUG=False

# PostgreSQL Configuration
POSTGRES_DB=dogs
POSTGRES_USER=dogs
POSTGRES_PASSWORD=change-this-to-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Application paths (inside container)
BASE_DATA_PATH=/app/data
