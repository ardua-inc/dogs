# Flask Configuration
FLASK_SECRET_KEY=change-me-to-a-secure-random-string
FLASK_CONFIG=production

# PostgreSQL Database
POSTGRES_DB=dogs
POSTGRES_USER=dogs
POSTGRES_PASSWORD=change-me-to-a-secure-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

