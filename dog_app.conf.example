# Example configuration file for the Comanche Dogs application
# Copy this file to dog_app.conf in the directory from which you run the application
# (e.g., ~/Documents/Code/dogs/grok/) or to /etc/dog_app.conf for production.
# Customize the values below for your environment.

[General]
# Base data path where the database and uploads (photos, medical records) are stored.
# For local development, use the absolute path to your dog_app directory.
# For production, use a path like /var/lib/dog_app.
base_data_path = /path/to/your/data

# Secret key for Flask session security. Use a unique, random string in production.
secret_key = your_secret_key_here

[Database]
# Database type: sqlite, mysql, or postgresql
type = sqlite

# SQLite settings
# Path to the SQLite database file, relative to base_data_path
sqlite_database = database.db

# MySQL settings
mysql_host = localhost
mysql_user = your_mysql_user
mysql_password = your_mysql_password
mysql_database = comanche_dogs

# PostgreSQL settings
postgresql_host = localhost
postgresql_user = your_postgresql_user
postgresql_password = your_postgresql_password
postgresql_database = comanche_dogs